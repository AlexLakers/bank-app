<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="create_dead_letter_queue" author="alexlakers">
        <preConditions>
            <not>
                <sequenceExists sequenceName="dlq_sequence"/>
            </not>
        </preConditions>
        <createSequence sequenceName="dlq_sequence" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="dlq_sequence"/>
        </rollback>
    </changeSet>

    <changeSet id="create_dlq_table" author="alexlakers">
        <preConditions>
            <not>
                <tableExists tableName="dead_letter_queue"/>
            </not>
        </preConditions>
        <createTable tableName="dead_letter_queue">
            <column name="id" type="bigint"
                    defaultValueSequenceNext="dlq_sequence">
                <constraints primaryKey="true"/>
            </column>
            <column name="msg_topic" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="msg_partition" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="msg_offset" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="msg_key" type="varchar(256)">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="varchar(1024)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="dead_letter_queue"/>
        </rollback>
    </changeSet>
</databaseChangeLog>