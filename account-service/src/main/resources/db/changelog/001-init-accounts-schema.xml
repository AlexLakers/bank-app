<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="create_accounts_sequence" author="alexlakers">
        <preConditions>
            <not>
                <sequenceExists sequenceName="accounts_sequence"/>
            </not>
        </preConditions>
        <createSequence sequenceName="accounts_sequence" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="accounts_sequence"/>
        </rollback>
    </changeSet>

    <changeSet id="create_accounts_table" author="alexlakers">
        <preConditions>
            <not>
                <tableExists tableName="accounts"/>
            </not>
        </preConditions>
        <createTable tableName="accounts">
            <column name="id" type="bigint"
                    defaultValueSequenceNext="accounts_sequence">
                <constraints primaryKey="true"/>
            </column>
            <column name="username" type="varchar(64)">
                <constraints nullable="false"
                             unique="true"/>
            </column>
            <column name="name" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="birth_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="balance" type="DECIMAL(19,2)">
                <constraints nullable="false"
                             checkConstraint="balance >= 0"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="accounts"/>
        </rollback>
    </changeSet>
</databaseChangeLog>